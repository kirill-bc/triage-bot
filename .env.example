# Copy to `.env` and fill in. Never commit `.env`.

# Required for API clients
JIRA_API_KEY=
OPENROUTER_API_KEY=

# Jira Cloud REST (set before the Jira fetcher is used)
# JIRA_BASE_URL=https://your-domain.atlassian.net
# JIRA_USER_EMAIL=your-atlassian-account@example.com

# Logging (optional)
# LOG_LEVEL=INFO
# LOGGING_API_KEY=
# LOGGING_ENDPOINT=
