# Copy to `.env` and fill in. Never commit `.env`.

# Required for API clients
JIRA_API_KEY=
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-4o-mini
# Live OpenRouter smoke (optional): export OPENROUTER_LIVE_SMOKE=1 then pytest -m integration

# Jira Cloud REST (set before the Jira fetcher is used)
# JIRA_USER_EMAIL=your-atlassian-account@example.com
# Prefer Atlassian gateway (same as curl -u email:api_key):
# JIRA_CLOUD_ID=your-site-cloud-id
# Or classic site URL (issue fetch only if you omit CLOUD_ID):
# JIRA_BASE_URL=https://your-domain.atlassian.net

# Logging (optional)
# LOG_LEVEL=INFO
# LOGGING_API_KEY=
# LOGGING_ENDPOINT=
