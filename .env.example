# Copy to `.env` and fill in. Never commit `.env`.

# Required for API clients
JIRA_API_KEY=
OPENROUTER_API_KEY=
TRIAGE_WEBHOOK_TOKEN=
# OPENROUTER_MODEL=openai/gpt-4o-mini
# TRIAGE_OPENROUTER_HTTP_TIMEOUT_SECONDS=60
# TRIAGE_OPENROUTER_HTTP_MAX_RETRIES=2
# Live OpenRouter smoke (optional): export OPENROUTER_LIVE_SMOKE=1 then pytest -m integration

# Jira Cloud REST (set before the Jira fetcher is used)
# JIRA_USER_EMAIL=your-atlassian-account@example.com
# Atlassian gateway (same as curl -u email:api_key):
# JIRA_CLOUD_ID=your-site-cloud-id
# Optional custom Jira field id for reproduction steps (default customfield_10251)
# TRIAGE_JIRA_REPRODUCTION_STEPS_FIELD_ID=customfield_10251

# Logging (optional)
# LOG_LEVEL=INFO
# LOGGING_API_KEY=
# LOGGING_ENDPOINT=
