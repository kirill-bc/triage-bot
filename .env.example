# Copy to `.env` and fill in. Never commit `.env`.

# Required for API clients
JIRA_API_KEY=
OPENROUTER_API_KEY=
TRIAGE_WEBHOOK_TOKEN=
# TRIAGE_TEXT_MODEL=openai/gpt-4o-mini
# TRIAGE_OPENROUTER_HTTP_TIMEOUT_SECONDS=60
# TRIAGE_OPENROUTER_HTTP_MAX_RETRIES=2

# Image attachment preprocessing (vision → text in issue_block; default off)
# TRIAGE_IMAGE_CONTEXT_ENABLED=false
# TRIAGE_VISION_MODEL=google/gemini-2.0-flash-001
# TRIAGE_IMAGE_CONTEXT_MAX_ATTACHMENTS=5
# TRIAGE_IMAGE_CONTEXT_MAX_BYTES_PER_IMAGE=5242880
# TRIAGE_IMAGE_CONTEXT_TIMEOUT_SECONDS=90
# TRIAGE_AUDIT_REDACT_IMAGE_TRANSCRIPT=true
# Live OpenRouter smoke (optional): export OPENROUTER_LIVE_SMOKE=1 then pytest -m integration

# Prompt management via Langfuse (optional; falls back to local prompt_templates.json if unset/unavailable)
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
# TRIAGE_LANGFUSE_PROMPTS_ENABLED=true
# TRIAGE_LANGFUSE_REASON_FOR_HUMANS_PROMPT_NAME=triagebot/reason-for-humans
# TRIAGE_LANGFUSE_CLASSIFICATION_PROMPT_NAME=triagebot/classification-user
# TRIAGE_LANGFUSE_PRIORITY_PROMPT_NAME=triagebot/priority-user
# TRIAGE_LANGFUSE_CLASSIFICATION_SYSTEM_PROMPT_NAME=triagebot/classification-system
# TRIAGE_LANGFUSE_PRIORITY_SYSTEM_PROMPT_NAME=triagebot/priority-system
# TRIAGE_LANGFUSE_VISION_SYSTEM_PROMPT_NAME=triagebot/vision-system
# TRIAGE_LANGFUSE_VISION_USER_PROMPT_NAME=triagebot/vision-user
# TRIAGE_LANGFUSE_PROMPT_LABEL=production
# TRIAGE_LANGFUSE_PROMPT_CACHE_TTL_SECONDS=60

# Jira Cloud REST (set before the Jira fetcher is used)
# JIRA_USER_EMAIL=your-atlassian-account@example.com
# Atlassian gateway (same as curl -u email:api_key):
# JIRA_CLOUD_ID=your-site-cloud-id
# Optional custom Jira field id for reproduction steps (default customfield_10251)
# TRIAGE_JIRA_REPRODUCTION_STEPS_FIELD_ID=customfield_10251

# Logging (optional)
# LOG_LEVEL=INFO
# LOGGING_API_KEY=
# LOGGING_ENDPOINT=
